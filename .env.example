# ──────────────────────────────────────────────────────────────
# Supabase 环境变量配置
# ──────────────────────────────────────────────────────────────
# 项目仅支持云 Supabase，localhost / 127.0.0.1 / ::1 / *.local 的 URL 会被拒绝。
#
# 环境变量命名优先级：COZE_SUPABASE_* > SUPABASE_*（legacy 兼容）
# ──────────────────────────────────────────────────────────────

# 必填：云 Supabase 实例 URL
COZE_SUPABASE_URL=https://cdcnjtgabgjkouavwxsl.supabase.co

# 必填：匿名访问 Key（公开安全，仅受 RLS 保护）
COZE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNkY25qdGdhYmdqa291YXZ3eHNsIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzc4NTIzNDEsImV4cCI6MjA5MzQyODM0MX0.HM6oAvBbY-PCDXbMpR_H4swyKprHM58mXP44u3onXEQ

# 必填：服务端管理 Key（保密！用于绕过 RLS 的服务端操作）
COZE_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNkY25qdGdhYmdqa291YXZ3eHNsIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3Nzg1MjM0MSwiZXhwIjoyMDkzNDI4MzQxfQ.LzvwvnkQx_lIjIjsZd8FxyXRaDwTPyiVELyTEuTacmE

